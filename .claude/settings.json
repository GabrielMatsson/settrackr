{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git status)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git rev-parse*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run lint*)",
      "Bash(npm run check*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "PowerShell(npm run typecheck*)",
      "PowerShell(npm run lint*)",
      "PowerShell(npm run check*)",
      "PowerShell(npm test*)",
      "PowerShell(npm run test*)",
      "PowerShell(npm run build*)",
      "PowerShell(.\\healthcheck.ps1*)",
      "PowerShell(Invoke-WebRequest -UseBasicParsing https://settrackr.onrender.com*)",
      "PowerShell(Invoke-WebRequest -UseBasicParsing https://settrackr.vercel.app*)",
      "PowerShell(Invoke-RestMethod -Uri https://settrackr.onrender.com*)"
    ]
  }
}
